# Doxygen config for the ds.* Lua scripting API + its C++ engine bindings.
#
# Lua isn't a language Doxygen understands natively (it only recognizes //
# and /* */ comments) -- FILTER_PATTERNS routes every .lua file through
# lua_doxygen_filter.py first, which rewrites this project's "---" doc
# comments above `function ds.module.name(...)` definitions into synthetic
# C++ declarations the EXTENSION_MAPPING below tells Doxygen's C++ parser to
# read. See lua_doxygen_filter.py's header comment for the full convention.
#
# Run from the repo root:
#   doxygen docs/Doxyfile
# Output lands in docs/generated/html/index.html (gitignored).
#
# Only a subset of options are set explicitly here; everything else uses
# Doxygen's built-in defaults.

PROJECT_NAME           = "DoomScroller"
PROJECT_BRIEF          = "Engine + ds.* Lua scripting API reference"
OUTPUT_DIRECTORY       = docs/generated
INPUT_ENCODING         = UTF-8
TAB_SIZE               = 4

# --- What gets scanned -------------------------------------------------------
# Lua scripts (the actual ds.* API surface) + the engine headers that define
# the C++ side of the same API (ScriptSystem's wrapper methods, the userdata
# infra, ds.Global) + ScriptSystem.cpp specifically for the l_* Lua-callable
# trampolines (ds.spawn_enemy, ds.level.add_box, etc.), which are only
# implemented there, not declared in a header.
INPUT                  = assets/scripts \
                          engine/include/engine/ScriptSystem.h \
                          engine/include/engine/script \
                          engine/src/ScriptSystem.cpp
FILE_PATTERNS           = *.h *.cpp *.lua
RECURSIVE               = YES
EXCLUDE_PATTERNS        =

# --- Lua support via the comment-rewriting filter ---------------------------
FILTER_PATTERNS         = *.lua=docs/lua_doxygen_filter.py
EXTENSION_MAPPING       = lua=C++

# --- Extraction scope --------------------------------------------------------
# Only what's deliberately documented (every synthetic Lua declaration always
# has a doc comment; on the C++ side only the genuinely Lua-facing API got
# Doxygen comments this pass) -- not a dump of the whole engine's internals.
EXTRACT_ALL             = NO
EXTRACT_PRIVATE         = NO
EXTRACT_STATIC          = YES
HIDE_UNDOC_MEMBERS      = YES
HIDE_UNDOC_CLASSES      = YES

# --- Warnings: catch doc/signature mismatches, stay quiet on the rest -------
WARNINGS                = YES
WARN_IF_UNDOCUMENTED    = NO
WARN_IF_DOC_ERROR       = YES
WARN_NO_PARAMDOC        = YES

# --- Output -------------------------------------------------------------------
GENERATE_HTML           = YES
HTML_OUTPUT             = html
GENERATE_LATEX          = NO
GENERATE_MAN            = NO
GENERATE_RTF            = NO
QUIET                   = NO
